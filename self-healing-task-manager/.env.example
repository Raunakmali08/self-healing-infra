# Copy to `.env` in this directory: `cp .env.example .env`
# Docker Compose reads these for substitution and passes them into containers.

# --- PostgreSQL (container + init) ---
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tasks
POSTGRES_PORT=5432

# Connection string for the Node backend (hostname `postgres` = Docker DNS on app-network).
# WHY DATABASE_URL: `pg` reads one string; avoids duplicating host/port/db across many vars in code.
DATABASE_URL=postgres://taskuser:change_me_strong_password@postgres:5432/tasks

# --- Backend ---
BACKEND_PORT=3000
PG_POOL_MAX=10

# --- Frontend (nginx listens on 80 inside the container; host port is mapped here) ---
FRONTEND_PORT=80
