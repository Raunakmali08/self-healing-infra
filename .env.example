# Copy to `.env` in this directory (same folder as docker-compose.yml).
# docker-compose loads `.env` automatically for ${VAR} substitution.
#
# TELEGRAM_TOKEN — from @BotFather (secret; never commit `.env`)
# TELEGRAM_ADMIN — your numeric Telegram user id (from getUpdates after /start)
TELEGRAM_TOKEN=replace-with-bot-token
TELEGRAM_ADMIN=replace-with-your-chat-id
